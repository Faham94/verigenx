{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VeriGenX Test Plan Schema",
  "description": "Schema for structured JSON test plans generated by SpecMind and consumed by all downstream agents",
  "type": "object",
  "required": ["design_name", "version", "generated_at", "signals", "fsm_states", "register_map", "functional_points"],
  "properties": {
    "design_name": {
      "type": "string",
      "description": "RTL design identifier (e.g., uart, axi4, spi)"
    },
    "version": {
      "type": "string",
      "description": "Test plan version (semantic versioning)"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of test plan generation"
    },
    "signals": {
      "type": "array",
      "description": "List of interface signals extracted from the specification",
      "items": {
        "type": "object",
        "required": ["name", "width", "direction"],
        "properties": {
          "name":      { "type": "string" },
          "width":     { "type": "integer", "minimum": 1 },
          "direction": { "type": "string", "enum": ["input", "output", "inout"] }
        }
      }
    },
    "fsm_states": {
      "type": "array",
      "description": "List of FSM state names extracted from the specification",
      "items": { "type": "string" }
    },
    "register_map": {
      "type": "array",
      "description": "Register map entries extracted from the specification",
      "items": {
        "type": "object",
        "required": ["address", "name", "width"],
        "properties": {
          "address": { "type": "string" },
          "name":    { "type": "string" },
          "width":   { "type": "integer", "minimum": 1 }
        }
      }
    },
    "functional_points": {
      "type": "array",
      "description": "Functional coverage points for the verification plan",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id":          { "type": "string", "pattern": "^FP_[0-9]{3,}$" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
